# Convex deployment URL. `npx convex dev` writes the real value to .env.local
# for local development. In production (Vercel), this is set automatically by
# `npx convex deploy --cmd 'npm run build'` using CONVEX_DEPLOY_KEY.
NEXT_PUBLIC_CONVEX_URL=

# Required for the speech product at /coach.
OPENAI_API_KEY=

# Optional model overrides. The defaults match the current implementation.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_SCORING_MODEL=gpt-5.6

# Optional: if omitted, Blunt falls back to written critique only.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
